{% set threshold = threshold | default(20) %}
{% set rechargeable = label_entities('rechargeable') %}
{% set battery_type_map = {
  'battery_aa':     'AA',
  'battery_aaa':    'AAA',
  'battery_cr2032': 'CR2032',
  'battery_cr2450': 'CR2450',
  'battery_9v':     '9V',
  'battery_d':      'D'
} %}
{% set battery_sensors = states.sensor
     | selectattr('attributes.device_class', 'defined')
     | selectattr('attributes.device_class', 'eq', 'battery')
     | rejectattr('entity_id', 'in', rechargeable)
     | list %}
{% if battery_sensors | length == 0 %}Keine batteriebetriebenen Sensoren gefunden.
{% else %}
{% set ns = namespace(low=[]) %}
{% for s in battery_sensors %}
{% if s.state not in ['unavailable', 'unknown'] and s.state | int(-1) <= threshold %}
{% set ns2 = namespace(type='') %}
{% for label, display in battery_type_map.items() %}
{% if s.entity_id in label_entities(label) %}{% set ns2.type = display %}{% endif %}
{% endfor %}
{% set ns3 = namespace(parts=[s.state ~ '%']) %}
{% if ns2.type %}{% set ns3.parts = ns3.parts + [ns2.type] %}{% endif %}
{% set helper_id = 'input_datetime.' ~ s.entity_id.split('.')[1] ~ '_replaced' %}
{% set replaced_state = states(helper_id) %}
{% if replaced_state not in ['unknown', 'unavailable', ''] %}
{% set days_since = ((now().timestamp() - as_datetime(replaced_state).timestamp()) / 86400) %}
{% set capacity_used = 100 - s.state | int(0) %}
{% if days_since > 1 and capacity_used > 0 %}
{% set days_remaining = (s.state | int(0) / (capacity_used / days_since)) | round(0) | int %}
{% set ns3.parts = ns3.parts + ['~' ~ days_remaining ~ ' Tage'] %}
{% endif %}
{% endif %}
{% set ns.low = ns.low + [s.name ~ ' (' ~ ns3.parts | join(', ') ~ ')'] %}
{% endif %}
{% endfor %}
{% if ns.low | length == 1 %}Folgendes Gerät hat einen niedrigen Akkustand: {{ ns.low | join(', ') }}
{% elif ns.low | length > 1 %}Folgende Geräte haben niedrigen Akkustand: {{ ns.low | join(', ') }}
{% endif %}
{% endif %}
