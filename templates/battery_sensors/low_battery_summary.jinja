{% set threshold = threshold | default(20) %}
{% set battery_sensors = states.sensor
     | selectattr('attributes.device_class', 'defined')
     | selectattr('attributes.device_class', 'eq', 'battery')
     | list %}
{% if battery_sensors | length == 0 %}Keine batteriebetriebenen Sensoren gefunden.
{% else %}
{% set ns = namespace(low=[]) %}
{% for s in battery_sensors %}
{% if s.state not in ['unavailable', 'unknown'] and s.state | int(-1) <= threshold %}
{% set ns.low = ns.low + [s.name ~ ' (' ~ s.state ~ '%)'] %}
{% endif %}
{% endfor %}
{% if ns.low | length > 0 %}Folgende Geräte haben niedrigen Akkustand: {{ ns.low | join(', ') }}
{% endif %}
{% endif %}
