{% set today = now().date() | string %}
{% set today_forecast = namespace(slots=[]) %}
{% for slot in forecast %}
{% if (slot.datetime | as_datetime).date() | string == today %}{% set today_forecast.slots = today_forecast.slots + [slot] %}{% endif %}
{% endfor %}
{% set rainy = today_forecast.slots | selectattr('precipitation', 'gt', 0) | list %}
{% if rainy | length == 0 %}Heute bleibt es trocken
{% else %}
{% set ns = namespace(groups=[], current=[rainy[0]]) %}
{% for slot in rainy[1:] %}
{% set prev_hour = (ns.current[-1].datetime | as_datetime).hour %}
{% set curr_hour = (slot.datetime | as_datetime).hour %}
{% if curr_hour == prev_hour + 1 %}
{% set ns.current = ns.current + [slot] %}
{% else %}
{% set ns.groups = ns.groups + [ns.current] %}
{% set ns.current = [slot] %}
{% endif %}
{% endfor %}
{% set ns.groups = ns.groups + [ns.current] %}
{% if rainy | length == today_forecast.slots | length %}Heute regnet es den ganzen Tag
{% else %}
{% set ns2 = namespace(parts=[]) %}
{% for group in ns.groups %}
{% set start = (group[0].datetime | as_datetime).hour %}
{% set end = (group[-1].datetime | as_datetime).hour + 1 %}
{% set ns2.parts = ns2.parts + ["von " ~ start ~ " bis " ~ end ~ " Uhr"] %}
{% endfor %}
Heute regnet es {{ ns2.parts | join(" und ") }}
{% endif %}
{% endif %}
