# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Hostname or IP address of your Home Assistant instance
HA_HOST=homeassistant.local

# SSH username — always "root" on HA OS
HA_USER=root

# SSH port — default is 22; change if you configured a different port in the Terminal & SSH app
HA_SSH_PORT=22

# Path to your ECDSA private key (the matching public key must be added to the Terminal & SSH app config)
HA_SSH_KEY=~/.ssh/id_ecdsa

# Long-lived access token — create one at: HA → Profile → Security → Long-lived access tokens
HA_TOKEN=your_long_lived_token_here
